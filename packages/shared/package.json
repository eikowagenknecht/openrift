{
  "name": "@openrift/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schemas": "./src/schemas.ts",
    "./db": "./src/db/index.ts",
    "./db/connect": "./src/db/connect.ts",
    "./db/migrate": "./src/db/migrate.ts",
    "./utils": "./src/utils.ts",
    "./services/price-refresh": "./src/services/price-refresh/index.ts",
    "./keywords": "./src/keywords.ts",
    "./types": "./src/types/index.ts",
    "./logger": "./src/logger.ts"
  },
  "scripts": {
    "test": "bun test src",
    "test:integration": "bun --env-file=../../.env test src/**/*.integration.test.ts",
    "build": "tsc",
    "typecheck": "tsc",
    "dev": "tsc --watch",
    "db:migrate": "bun --env-file=../../.env ../../scripts/run-migrations.ts",
    "db:rollback": "bun --env-file=../../.env ../../scripts/run-migrations.ts down",
    "make-admin": "bun --env-file=../../.env ../../scripts/make-admin.ts"
  },
  "dependencies": {
    "kysely": "0.28.11",
    "kysely-postgres-js": "3.0.0",
    "pino": "10.3.1",
    "postgres": "3.4.8",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bun": "1.3.10",
    "typescript": "5.9.3"
  }
}
