{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@api/*": ["../../apps/api/src/*"]
    }
  },
  "include": ["src/**/*.ts", "playwright.config.ts"]
}
