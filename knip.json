{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/**/*.ts"],
      "project": ["scripts/**/*.ts"]
    },
    "apps/api": {
      "entry": ["src/app.ts"],
      "ignore": [
        "src/**/*.test.ts",
        "src/**/*.integration.test.ts",
        "src/test/**",
        "src/db/migrations/*.ts"
      ]
    },
    "apps/web": {
      "entry": [
        "src/client.tsx",
        "src/server.ts",
        "src/start.ts",
        "src/router.ts",
        "src/routes/**/*.tsx",
        "src/components/cards/card-detail/index.tsx"
      ],
      "ignore": ["src/env.d.ts", "src/components/ui/**", "src/**/*.bench.ts"],
      "ignoreDependencies": ["@tanstack/router-cli", "@tanstack/router-plugin"]
    },
    "packages/shared": {},
    "packages/e2e": {
      "entry": ["src/**/*.spec.ts", "src/**/*.setup.ts"],
      "ignore": []
    }
  },
  "ignoreBinaries": ["wait"]
}
