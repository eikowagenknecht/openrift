{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Container Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\".+\",name!~\".*monitoring.*\"}",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Container CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\".+\",name!~\".*monitoring.*\"}[5m])",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Container Network Received",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "min": 0,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(container_network_receive_bytes_total{name=~\".+\",name!~\".*monitoring.*\"}[5m])",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Container Network Transmitted",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "min": 0,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(container_network_transmit_bytes_total{name=~\".+\",name!~\".*monitoring.*\"}[5m])",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Container Restarts",
      "type": "stat",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 30 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "increase(container_start_time_seconds{name=~\".+\",name!~\".*monitoring.*\"}[24h])",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["cadvisor", "containers"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Container Metrics",
  "uid": "openrift-containers",
  "version": 1
}
