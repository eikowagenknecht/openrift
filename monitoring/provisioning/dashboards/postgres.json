{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          },
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "pg_stat_activity_count{datname=\"openrift\"}",
          "legendFormat": "{{ state }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Max Connections",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "thresholds": {
            "mode": "percentage",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(pg_stat_activity_count{datname=\"openrift\"})",
          "legendFormat": "Active",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Database Size",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1073741824 },
              { "color": "red", "value": 10737418240 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "pg_database_size_bytes{datname=\"openrift\"}",
          "legendFormat": "Size",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Transactions per Second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname=\"openrift\"}[5m])",
          "legendFormat": "Commits/s",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{datname=\"openrift\"}[5m])",
          "legendFormat": "Rollbacks/s",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Tuples (rows) per Second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_fetched{datname=\"openrift\"}[5m])",
          "legendFormat": "Fetched/s",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_tup_inserted{datname=\"openrift\"}[5m])",
          "legendFormat": "Inserted/s",
          "refId": "B"
        },
        {
          "expr": "rate(pg_stat_database_tup_updated{datname=\"openrift\"}[5m])",
          "legendFormat": "Updated/s",
          "refId": "C"
        },
        {
          "expr": "rate(pg_stat_database_tup_deleted{datname=\"openrift\"}[5m])",
          "legendFormat": "Deleted/s",
          "refId": "D"
        }
      ]
    },
    {
      "title": "Cache Hit Ratio",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.99 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "pg_stat_database_blks_hit{datname=\"openrift\"} / (pg_stat_database_blks_hit{datname=\"openrift\"} + pg_stat_database_blks_read{datname=\"openrift\"})",
          "legendFormat": "Cache Hit Ratio",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Deadlocks",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_deadlocks{datname=\"openrift\"}[5m])",
          "legendFormat": "Deadlocks/s",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["postgres", "database"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "PostgreSQL",
  "uid": "openrift-postgres",
  "version": 1
}
