# User/group ID for file permissions (match your host user)
UID=1000
GID=1000

# Grafana
GRAFANA_ADMIN_PASSWORD=changeme
GRAFANA_PORT=3100
GRAFANA_DOMAIN=monitoring.openrift.app

# SMTP for email alerts
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASSWORD=changeme
SMTP_FROM=alerts@openrift.app
ALERT_EMAIL_TO=you@example.com

# PostgreSQL connection for postgres-exporter
# Use the same credentials as your main app's DATABASE_URL
POSTGRES_CONNECTION=postgresql://openrift:PASSWORD@db:5432/openrift?sslmode=disable

# Prometheus data retention (default: 90 days)
PROMETHEUS_RETENTION=90d
